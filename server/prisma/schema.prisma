datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
  engineType      = "library"
}

model Transcript {
  id        String   @id @default(uuid())
  text      String
  createdAt DateTime @default(now())
}

model Memory {
  id              String   @id @default(uuid())
  title           String
  summary         String
  category        String
  importance      Float
  rawTranscript   String?
  nextActionDate  DateTime?
  embedding       Unsupported("vector(3072)")? // Standard embedding size for gemini-embedding-001 
  createdAt       DateTime @default(now())
}
