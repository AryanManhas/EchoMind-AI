# Environment configuration template for Context Extraction Module

# API Settings
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# Storage
ELASTICSEARCH_URL=http://elasticsearch:9200
REDIS_URL=redis://redis:6379/0

# Model Settings
MODEL_NAME=bert-base-uncased
USE_QUANTIZATION=true
MAX_SEQ_LENGTH=512

# Security (If needed for auth with Node.js backend)
API_KEY=your_internal_api_key_here
